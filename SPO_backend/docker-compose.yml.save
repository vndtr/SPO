
services:

  
  db:
    image: postgres:18
    container_name: db
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: test
      POSTGRES_DB: shop
      POSTGRES_HOST_AUTH_METHOD: trust
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql
  minio:
    image: minio/minio:latest
    container_name: minio
    ports:^^^^666xx666^X^X^X^^X^X^      - "9000:9000"  # MinIO API
      - "9001:9001"  # MinIO Console
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin
    command: server /data --console-address ":9001"
    volumes:
      - minio_data:/data
  python_app:
    build: .
    depends_on:
      - db
      - minio
    container_name: python_app
    ports:
      - "5000:5000"
    volumes:
      - ./app:/app
    environment:
      - PYTHONUNBUFFERED=1
  adminer:
    image: adminer:latest
    container_name: adminer
    depends_on:
      - db
    ports:
      - "8080:8080"  
    environment:
      - ADMINER_DEFAULT_SERVER=db

volumes:
  postgres_data:
  minio_data:
